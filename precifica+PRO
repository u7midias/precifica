<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Precifica+ PRO</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#f4efe7;
  --surface:#fffdf8;
  --soft:#f8efe3;
  --border:#e4d3bd;
  --text:#201812;
  --muted:#74675b;
  --light:#a99b8c;
  --accent:#7a4f2a;
  --accent-dark:#3d2413;
  --gold:#c49a5a;
  --green-bg:#edf7f0;
  --green:#17613b;
  --green-b:#b6dec7;
  --warn-bg:#fff4df;
  --warn:#7a4f0d;
  --red-bg:#fdecea;
  --red:#8b1f1f;
  --radius:22px;
  --radius-sm:12px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{
  font-family:'DM Sans',sans-serif;
  color:var(--text);
  min-height:100vh;
  padding:28px;
  background:
    radial-gradient(circle at 10% 0%, rgba(196,154,90,.28), transparent 30%),
    linear-gradient(135deg,#f8f3eb 0%,#ede3d6 100%);
}
.container{max-width:1180px;margin:0 auto}
.hero{
  display:grid;
  grid-template-columns:1.25fr .75fr;
  gap:20px;
  align-items:stretch;
  margin-bottom:20px;
}
.hero-main{
  padding:34px;
  border-radius:30px;
  background:linear-gradient(135deg,#fffdf8 0%,#f3e5d3 100%);
  border:1px solid rgba(196,154,90,.38);
  box-shadow:0 24px 60px rgba(61,36,19,.10);
}
.eyebrow{
  font-size:12px;
  font-weight:800;
  letter-spacing:2.2px;
  color:var(--accent);
  text-transform:uppercase;
  margin-bottom:12px;
}
h1{
  font-size:clamp(38px,5vw,64px);
  letter-spacing:-2.5px;
  line-height:.95;
  margin-bottom:16px;
}
.hero p{
  color:var(--muted);
  font-size:17px;
  max-width:680px;
  line-height:1.55;
}
.hero-side{
  padding:26px;
  border-radius:30px;
  background:linear-gradient(135deg,var(--accent-dark),var(--accent));
  color:#fff;
  box-shadow:0 24px 60px rgba(61,36,19,.16);
}
.hero-side .small{font-size:12px;text-transform:uppercase;letter-spacing:2px;opacity:.72;margin-bottom:14px;font-weight:800}
.hero-side .big{font-size:34px;font-weight:800;letter-spacing:-1px;margin-bottom:8px}
.hero-side p{color:rgba(255,255,255,.78);font-size:14px}
.tabs{
  display:flex;
  gap:6px;
  padding:6px;
  width:fit-content;
  background:rgba(255,253,248,.8);
  border:1px solid var(--border);
  border-radius:999px;
  margin-bottom:20px;
  box-shadow:0 10px 30px rgba(61,36,19,.06);
}
.tab{
  border:0;
  background:transparent;
  color:var(--muted);
  border-radius:999px;
  padding:11px 20px;
  font-family:'DM Sans';
  font-weight:800;
  cursor:pointer;
}
.tab.active{background:var(--accent-dark);color:#fff}
.panel{display:none}
.panel.active{display:block}
.grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:18px;
  align-items:start;
}
.card{
  background:rgba(255,253,248,.94);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:24px;
  margin-bottom:18px;
  box-shadow:0 16px 40px rgba(61,36,19,.07);
}
.card-title{
  display:flex;
  gap:10px;
  align-items:center;
  margin-bottom:14px;
}
.num{
  width:30px;height:30px;border-radius:50%;
  background:var(--accent-dark);color:#fff;
  display:flex;align-items:center;justify-content:center;
  font-size:13px;font-weight:800;
}
.section-label{
  font-size:12px;
  font-weight:800;
  text-transform:uppercase;
  letter-spacing:1.2px;
  color:var(--accent);
}
.helper{
  color:var(--muted);
  font-size:13px;
  line-height:1.5;
  margin-bottom:14px;
}
label{
  display:block;
  margin-top:14px;
  margin-bottom:6px;
  font-size:12px;
  color:var(--muted);
  font-weight:800;
  text-transform:uppercase;
  letter-spacing:.45px;
}
input,select,textarea{
  width:100%;
  padding:12px 13px;
  border:1px solid var(--border);
  border-radius:var(--radius-sm);
  background:var(--surface);
  color:var(--text);
  font-family:'DM Sans';
  font-size:14px;
  outline:none;
}
textarea{min-height:86px;resize:vertical}
input:focus,select:focus,textarea:focus{
  border-color:var(--accent);
  box-shadow:0 0 0 4px rgba(122,79,42,.08);
}
.btn{
  padding:12px 17px;
  border:1px solid #c8b59b;
  border-radius:var(--radius-sm);
  background:var(--surface);
  color:var(--text);
  font-family:'DM Sans';
  font-size:13px;
  font-weight:800;
  cursor:pointer;
}
.btn-primary{
  background:linear-gradient(135deg,var(--accent-dark),var(--accent));
  color:#fff;
  border-color:var(--accent);
  box-shadow:0 12px 26px rgba(61,36,19,.17);
}
.btn-danger{background:var(--red-bg);color:var(--red);border-color:#f5b8b8}
.metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.metric{
  padding:18px;
  border-radius:18px;
  border:1px solid var(--border);
  background:var(--soft);
}
.metric-label{
  font-size:11px;
  color:var(--muted);
  font-weight:800;
  text-transform:uppercase;
  letter-spacing:.6px;
  margin-bottom:6px;
}
.metric-value{
  font-family:'DM Mono';
  font-weight:800;
  font-size:22px;
  letter-spacing:-.8px;
}
.result-card{
  position:sticky;
  top:20px;
  text-align:center;
  background:linear-gradient(135deg,#fffdf8,#f3e5d3);
}
.big-value{
  font-family:'DM Mono';
  font-size:clamp(38px,5vw,58px);
  font-weight:800;
  letter-spacing:-2px;
  color:var(--accent-dark);
  margin:8px 0 6px;
}
.item{
  display:flex;
  gap:10px;
  align-items:center;
  border-bottom:1px solid var(--border);
  padding:11px 0;
  flex-wrap:wrap;
}
.item:last-child{border-bottom:0}
.item-name{flex:1;font-size:14px}
.badge{
  font-family:'DM Mono';
  font-size:11px;
  font-weight:800;
  padding:5px 9px;
  border-radius:999px;
  background:#efe8ff;
  color:#4b2b86;
  border:1px solid #d6c3ff;
}
.alerta{
  padding:12px 14px;
  border-radius:var(--radius-sm);
  border:1px solid;
  font-size:13px;
  line-height:1.5;
  text-align:left;
}
.ok{background:var(--green-bg);color:var(--green);border-color:var(--green-b)}
.warn{background:var(--warn-bg);color:var(--warn);border-color:#f0d39a}
.bad{background:var(--red-bg);color:var(--red);border-color:#f5b8b8}
.preview{
  background:#fffdf8;
  border-radius:28px;
  overflow:hidden;
  border:1px solid var(--border);
  box-shadow:0 24px 60px rgba(61,36,19,.10);
}
.preview-hero{
  padding:36px;
  color:#fff;
  background:linear-gradient(135deg,#2b1d12,#7a4f2a);
}
.preview-title{
  font-size:36px;
  font-weight:800;
  letter-spacing:-1.3px;
  margin-bottom:8px;
}
.preview-body{padding:34px}
.preview-grid{display:grid;grid-template-columns:1.25fr .75fr;gap:28px}
.preview-section{margin-bottom:26px}
.preview-section h3{
  font-size:12px;
  text-transform:uppercase;
  letter-spacing:1.4px;
  color:var(--accent);
  margin-bottom:12px;
}
.preview-section p{color:#4a3a2b;line-height:1.65}
.price-box{
  padding:22px;
  border-radius:20px;
  background:#f5ede2;
  border:1px solid var(--border);
}
.price{
  font-family:'DM Mono';
  font-size:32px;
  font-weight:800;
  color:var(--accent-dark);
}
.side-info{
  margin-top:12px;
  padding:16px;
  border-radius:16px;
  border:1px solid var(--border);
  background:#fffaf2;
}
.side-info small{
  display:block;
  color:var(--muted);
  text-transform:uppercase;
  letter-spacing:.8px;
  font-weight:800;
  font-size:10px;
  margin-bottom:4px;
}
.side-info strong{font-size:14px}
.actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:12px}
.history-card{
  display:flex;
  justify-content:space-between;
  gap:12px;
  flex-wrap:wrap;
  padding:18px;
  border:1px solid var(--border);
  border-radius:18px;
  background:var(--surface);
  margin-bottom:10px;
}
.no-print{}
@media(max-width:900px){
  body{padding:16px}
  .hero,.grid,.preview-grid,.metrics{grid-template-columns:1fr}
  .tabs{width:100%}
  .tab{flex:1}
  .result-card{position:static}
}
@media print{
  body{background:#fff!important;padding:0!important}
  .no-print,.hero,.tabs,#panel-base,#panel-historico,#montagem{display:none!important}
  .container{max-width:100%!important;margin:0!important}
  #panel-proposta{display:block!important}
  .preview{box-shadow:none!important;border:none!important;border-radius:0!important}
  @page{size:A4;margin:12mm}
}
</style>
</head>
<body>
<div class="container">
  <section class="hero no-print">
    <div class="hero-main">
      <div class="eyebrow">Precifica+ PRO</div>
      <h1>Sistema de propostas para prestadores de serviço</h1>
      <p>Calcule seu preço internamente, monte o escopo do cliente e gere uma proposta comercial bonita sem revelar horas, custo por hora ou lógica de precificação.</p>
    </div>
    <div class="hero-side">
      <div class="small">Fluxo premium</div>
      <div class="big">Base → Escopo → Proposta</div>
      <p>O prestador enxerga os números internos. O cliente recebe apenas escopo, valor total e condições comerciais.</p>
    </div>
  </section>

  <div class="tabs no-print">
    <button class="tab active" onclick="showTab('base', this)">1. Minha base</button>
    <button class="tab" onclick="showTab('proposta', this)">2. Proposta</button>
    <button class="tab" onclick="showTab('historico', this)">Histórico</button>
  </div>

  <section id="panel-base" class="panel active">
    <div class="grid">
      <div class="card">
        <div class="card-title">
          <div class="num">1</div>
          <div class="section-label">Minha base interna</div>
        </div>
        <p class="helper">Preencha seus custos e metas. Essa parte serve só para calcular sua hora recomendada.</p>

        <label>Custo de vida mensal (R$)</label>
        <input type="number" id="custo_vida" value="2500" oninput="calcTudo()">

        <label>Ferramentas, internet e assinaturas (R$)</label>
        <input type="number" id="custo_tools" value="300" oninput="calcTudo()">

        <label>Impostos / MEI / taxas (R$)</label>
        <input type="number" id="custo_imposto" value="300" oninput="calcTudo()">

        <label>Lucro desejado no mês (R$)</label>
        <input type="number" id="lucro" value="1500" oninput="calcTudo()">

        <label>Horas disponíveis para vender no mês</label>
        <input type="number" id="horas_mes" value="120" oninput="calcTudo()">

        <label>Margem de segurança (%)</label>
        <input type="number" id="margem" value="20" oninput="calcTudo()">
      </div>

      <div>
        <div class="card">
          <div class="card-title">
            <div class="num">✓</div>
            <div class="section-label">Resultado da sua base</div>
          </div>
          <div class="metrics">
            <div class="metric">
              <div class="metric-label">Custo + lucro</div>
              <div class="metric-value" id="r-custo">R$ 0</div>
            </div>
            <div class="metric">
              <div class="metric-label">Hora mínima</div>
              <div class="metric-value" id="r-hora-min">R$ 0</div>
            </div>
            <div class="metric">
              <div class="metric-label">Hora recomendada</div>
              <div class="metric-value" id="r-hora-rec">R$ 0</div>
            </div>
          </div>
          <div class="alerta ok" style="margin-top:16px">
            Depois de configurar sua base, avance para montar o escopo do cliente.
          </div>

          <button class="btn btn-primary" style="width:100%;margin-top:14px" onclick="irPara('proposta')">
            Próximo passo: montar proposta →
          </button>
        </div>
      </div>
    </div>
  </section>

  <section id="panel-proposta" class="panel">
    <div class="no-print" style="margin-bottom:14px">
      <button class="btn" onclick="irPara('base')">← Voltar para minha base</button>
    </div>

    <div id="montagem" class="grid no-print">
      <div>
        <div class="card">
          <div class="card-title">
            <div class="num">2</div>
            <div class="section-label">Dados do cliente</div>
          </div>

          <label>Nome do cliente</label>
          <input type="text" id="cliente_nome" placeholder="Ex: Loja da Maria" oninput="renderPreview()">

          <label>Título do serviço</label>
          <input type="text" id="titulo_servico" placeholder="Ex: Gestão de Redes Sociais" oninput="renderPreview()">

          <label>Resumo da proposta</label>
          <textarea id="resumo_proposta" placeholder="Ex: Estruturação mensal de comunicação para fortalecer presença digital." oninput="renderPreview()"></textarea>
        </div>

        <div class="card">
          <div class="card-title">
            <div class="num">3</div>
            <div class="section-label">Escopo do cliente</div>
          </div>
          <p class="helper">Aqui você monta o escopo total. As horas são usadas só para calcular o valor recomendado e não aparecem na proposta final.</p>

          <label>Entrega / demanda</label>
          <input type="text" id="demanda_nome" placeholder="Ex: Planejamento mensal de conteúdo">

          <label>Horas internas estimadas</label>
          <div style="display:flex;gap:8px">
            <input type="number" id="demanda_horas" placeholder="Horas" step="0.5">
            <button type="button" class="btn btn-primary" onclick="addDemanda()">Adicionar</button>
          </div>
        </div>

        <div class="card" id="escopo-card" style="display:none">
          <div class="section-label">Escopo calculado</div>
          <div id="lista-escopo"></div>
        </div>

        <div class="card">
          <div class="card-title">
            <div class="num">4</div>
            <div class="section-label">Condições comerciais</div>
          </div>

          <label>Valor total da proposta (R$)</label>
          <input type="number" id="valor_proposta" placeholder="Deixe vazio para usar o valor recomendado" oninput="renderPreview()">

          <label>Tipo de cobrança</label>
          <select id="tipo_cobranca" onchange="renderPreview()">
            <option>Mensal</option>
            <option>Projeto fechado</option>
            <option>Pacote único</option>
          </select>

          <label>Forma de pagamento</label>
          <select id="forma_pagamento" onchange="renderPreview()">
            <option>Pix</option>
            <option>Pix ou cartão</option>
            <option>Pix, boleto e cartão</option>
            <option>Transferência bancária</option>
          </select>

          <label>Parcelamento máximo</label>
          <select id="parcelamento_max" onchange="renderPreview()">
            <option>1x</option>
            <option>2x</option>
            <option selected>3x</option>
            <option>4x</option>
            <option>6x</option>
            <option>12x</option>
          </select>

          <label>Validade da proposta</label>
          <select id="validade_proposta" onchange="renderPreview()">
            <option>3 dias</option>
            <option selected>7 dias</option>
            <option>15 dias</option>
            <option>30 dias</option>
          </select>

          <label>Observações</label>
          <textarea id="obs_proposta" placeholder="Ex: Demandas fora do escopo serão orçadas separadamente." oninput="renderPreview()"></textarea>

          <div class="actions">
            <button class="btn btn-primary" onclick="salvarHistorico()">Salvar no histórico</button>
            <button class="btn btn-primary" onclick="baixarPDF()">Baixar proposta em PDF</button>
            <button class="btn" onclick="irPara('historico')">Ver histórico →</button>
          </div>
        </div>
      </div>

      <div>
        <div class="card result-card">
          <div class="section-label">Resultado interno</div>

          <div class="metric-label">Horas estimadas no escopo</div>
          <div class="metric-value" id="total-horas" style="font-size:32px;margin-bottom:18px">0h</div>

          <div class="metric-label">Valor recomendado</div>
          <div class="big-value" id="valor-final">R$ 0,00</div>

          <div id="alerta-final" style="margin-top:14px"></div>
        </div>
      </div>
    </div>

    <div class="preview" id="preview-proposta">
      <div class="preview-hero">
        <div style="font-size:12px;letter-spacing:2px;text-transform:uppercase;opacity:.72;margin-bottom:12px;font-weight:800">Proposta comercial</div>
        <div class="preview-title" id="pv-titulo">Proposta de Serviço</div>
        <div id="pv-cliente" style="opacity:.82">Cliente</div>
      </div>

      <div class="preview-body">
        <div class="preview-grid">
          <div>
            <div class="preview-section">
              <h3>Resumo</h3>
              <p id="pv-resumo">Proposta estruturada de acordo com o escopo solicitado e as condições comerciais definidas.</p>
            </div>

            <div class="preview-section">
              <h3>Escopo do serviço</h3>
              <div id="pv-escopo">—</div>
            </div>

            <div class="preview-section">
              <h3>Observações</h3>
              <p id="pv-obs">Demandas fora do escopo poderão ser orçadas separadamente.</p>
            </div>
          </div>

          <div>
            <div class="price-box">
              <div class="metric-label">Investimento</div>
              <div class="price" id="pv-valor">R$ 0,00</div>
              <p id="pv-tipo" style="font-size:12px;margin-top:4px">Mensal</p>
            </div>

            <div class="side-info">
              <small>Pagamento</small>
              <strong id="pv-pagamento">Pix</strong>
            </div>

            <div class="side-info">
              <small>Parcelamento</small>
              <strong id="pv-parcelamento">Até 3x</strong>
            </div>

            <div class="side-info">
              <small>Validade</small>
              <strong id="pv-validade">7 dias</strong>
            </div>
          </div>
        </div>

        <div style="margin-top:28px;padding:18px;border-radius:18px;background:#f5ede2;color:#4a3a2b">
          <strong>Próximo passo:</strong> para avançar, confirme a aprovação da proposta para alinharmos início, prazos e envio das informações necessárias.
        </div>
      </div>
    </div>
  </section>

  <section id="panel-historico" class="panel">
    <div class="card">
      <div class="card-title">
        <div class="num">H</div>
        <div class="section-label">Histórico local</div>
      </div>
      <p class="helper">As propostas ficam salvas neste navegador. Se limpar os dados do navegador, o histórico é apagado.</p>
      <button class="btn btn-danger" onclick="limparHistorico()">Limpar histórico</button>
      <div id="historico-lista" style="margin-top:16px"></div>
    </div>
  </section>
</div>

<script>
let horaMin = 0;
let horaRec = 0;
let escopo = [];
const STORAGE_KEY = 'precifica_plus_pro_layout_v1';

function fmt(v){
  return 'R$ ' + Number(v || 0).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.');
}
function fmtH(v){
  return Number(v || 0).toFixed(1).replace('.', ',') + 'h';
}
function showTab(id, el){
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.getElementById('panel-' + id).classList.add('active');
  el.classList.add('active');
  if(id === 'historico') renderHistorico();
  if(id === 'proposta') renderPreview();
}

function irPara(id){
  const tab = Array.from(document.querySelectorAll('.tab')).find(btn => btn.getAttribute('onclick')?.includes("'" + id + "'"));
  if(tab) showTab(id, tab);
  window.scrollTo({top: 0, behavior: 'smooth'});
}
function calcHora(){
  const total = (+custo_vida.value || 0) + (+custo_tools.value || 0) + (+custo_imposto.value || 0) + (+lucro.value || 0);
  const horas = +horas_mes.value || 1;
  const margem = +margem.value || 0;
  horaMin = total / horas;
  horaRec = horaMin * (1 + margem / 100);

  document.getElementById('r-custo').textContent = fmt(total);
  document.getElementById('r-hora-min').textContent = fmt(horaMin);
  document.getElementById('r-hora-rec').textContent = fmt(horaRec);
}
function totalHoras(){
  return escopo.reduce((s, item) => s + (+item.horas || 0), 0);
}
function valorRecomendado(){
  return totalHoras() * horaRec;
}
function calcTudo(){
  calcHora();
  const h = totalHoras();
  const valor = valorRecomendado();
  document.getElementById('total-horas').textContent = fmtH(h);
  document.getElementById('valor-final').textContent = fmt(valor);

  document.getElementById('alerta-final').innerHTML = h
    ? '<div class="alerta ok">Esse valor é calculado com base na sua hora recomendada e nas horas internas do escopo.</div>'
    : '<div class="alerta warn">Adicione entregas ao escopo para calcular o valor recomendado.</div>';

  renderPreview();
}
function addDemanda(){
  const nome = demanda_nome.value.trim();
  const horas = +demanda_horas.value;
  if(!nome || !horas){
    alert('Preencha a entrega e as horas internas estimadas.');
    return;
  }
  escopo.push({nome, horas});
  demanda_nome.value = '';
  demanda_horas.value = '';
  renderEscopo();
  calcTudo();
}
function removeDemanda(i){
  escopo.splice(i, 1);
  renderEscopo();
  calcTudo();
}
function renderEscopo(){
  const card = document.getElementById('escopo-card');
  const lista = document.getElementById('lista-escopo');

  if(!escopo.length){
    card.style.display = 'none';
    lista.innerHTML = '';
    return;
  }

  card.style.display = 'block';
  lista.innerHTML = escopo.map((item, i) => `
    <div class="item">
      <div class="item-name">${item.nome}</div>
      <span class="badge">${fmtH(item.horas)}</span>
      <button class="btn" style="padding:7px 10px" onclick="removeDemanda(${i})">×</button>
    </div>
  `).join('');
}
function escopoClienteHTML(){
  if(!escopo.length) return '<p style="color:#74675b">Nenhum item adicionado ainda.</p>';
  return escopo.map(item => `
    <div style="padding:12px 0;border-bottom:1px solid #e7d8c5;color:#4a3a2b">
      • ${item.nome}
    </div>
  `).join('');
}
function renderPreview(){
  const valorManual = +valor_proposta.value || 0;
  const valor = valorManual || valorRecomendado();

  document.getElementById('pv-titulo').textContent = titulo_servico.value || 'Proposta de Serviço';
  document.getElementById('pv-cliente').textContent = cliente_nome.value || 'Cliente';
  document.getElementById('pv-resumo').textContent = resumo_proposta.value || 'Proposta estruturada de acordo com o escopo solicitado e as condições comerciais definidas.';
  document.getElementById('pv-escopo').innerHTML = escopoClienteHTML();
  document.getElementById('pv-obs').textContent = obs_proposta.value || 'Demandas fora do escopo poderão ser orçadas separadamente.';
  document.getElementById('pv-valor').textContent = fmt(valor);
  document.getElementById('pv-tipo').textContent = tipo_cobranca.value;
  document.getElementById('pv-pagamento').textContent = forma_pagamento.value;
  document.getElementById('pv-parcelamento').textContent = 'Até ' + parcelamento_max.value;
  document.getElementById('pv-validade').textContent = validade_proposta.value;
}
function baixarPDF(){
  if(!escopo.length){
    alert('Adicione pelo menos uma entrega no escopo.');
    return;
  }
  renderPreview();
  setTimeout(() => window.print(), 250);
}
function getHistorico(){
  try{return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]')}catch(e){return []}
}
function setHistorico(arr){
  localStorage.setItem(STORAGE_KEY, JSON.stringify(arr));
}
function salvarHistorico(){
  if(!escopo.length){
    alert('Adicione pelo menos uma entrega no escopo.');
    return;
  }
  const valor = +valor_proposta.value || valorRecomendado();
  const hist = getHistorico();
  hist.unshift({
    id: Date.now(),
    data: new Date().toLocaleDateString('pt-BR'),
    cliente: cliente_nome.value || 'Cliente sem nome',
    titulo: titulo_servico.value || 'Proposta de Serviço',
    valor,
    escopo: [...escopo]
  });
  setHistorico(hist);
  alert('Proposta salva no histórico local.');
}
function renderHistorico(){
  const hist = getHistorico();
  const el = document.getElementById('historico-lista');

  if(!hist.length){
    el.innerHTML = '<div class="alerta warn">Nenhuma proposta salva ainda.</div>';
    return;
  }

  el.innerHTML = hist.map(p => `
    <div class="history-card">
      <div>
        <strong>${p.cliente}</strong>
        <p>${p.titulo} · ${p.data}</p>
        <p style="font-size:13px;margin-top:6px">${p.escopo.map(e => e.nome).join(' • ')}</p>
      </div>
      <div style="font-family:DM Mono;font-weight:800;color:var(--accent-dark)">${fmt(p.valor)}</div>
    </div>
  `).join('');
}
function limparHistorico(){
  if(confirm('Tem certeza que deseja apagar o histórico local?')){
    localStorage.removeItem(STORAGE_KEY);
    renderHistorico();
  }
}
document.addEventListener('DOMContentLoaded', () => {
  calcTudo();
  renderEscopo();
  renderPreview();

  demanda_nome.addEventListener('keypress', e => {
    if(e.key === 'Enter'){ e.preventDefault(); addDemanda(); }
  });
  demanda_horas.addEventListener('keypress', e => {
    if(e.key === 'Enter'){ e.preventDefault(); addDemanda(); }
  });
});
</script>
</body>
</html>
