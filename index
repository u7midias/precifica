<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Precifica+</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;800&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

html{
scroll-behavior:smooth;
}

body{
font-family:'DM Sans',sans-serif;
background:#f7f4ef;
color:#181818;
overflow-x:hidden;
}

.container{
width:100%;
max-width:1180px;
margin:auto;
padding:0 24px;
}

section{
padding:90px 0;
}

.hero{
min-height:100vh;
display:flex;
align-items:center;
background:
radial-gradient(circle at top left, rgba(111,78,55,.12), transparent 30%),
linear-gradient(to bottom,#f7f4ef,#efe8dc);
}

.hero-grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:60px;
align-items:center;
}

.badge{
display:inline-block;
padding:10px 18px;
border-radius:999px;
background:#ffffff;
border:1px solid #e4d9c9;
font-size:13px;
font-weight:700;
margin-bottom:24px;
color:#6d4c32;
}

.hero h1{
font-size:72px;
line-height:0.95;
letter-spacing:-4px;
margin-bottom:24px;
}

.hero h1 span{
color:#6d4c32;
}

.hero p{
font-size:20px;
line-height:1.6;
color:#555;
margin-bottom:36px;
max-width:560px;
}

.buttons{
display:flex;
gap:16px;
flex-wrap:wrap;
}

.btn{
padding:16px 28px;
border-radius:14px;
font-weight:700;
font-size:15px;
cursor:pointer;
text-decoration:none;
transition:.2s;
display:inline-flex;
align-items:center;
justify-content:center;
border:none;
}

.btn-primary{
background:#2a1a10;
color:white;
box-shadow:0 12px 30px rgba(42,26,16,.15);
}

.btn-primary:hover{
transform:translateY(-2px);
}

.btn-secondary{
background:white;
border:1px solid #ddd;
color:#222;
}

.mockup{
background:white;
border-radius:30px;
padding:24px;
border:1px solid #e5d9ca;
box-shadow:0 30px 60px rgba(0,0,0,.08);
}

.mockup-top{
display:flex;
gap:8px;
margin-bottom:20px;
}

.dot{
width:12px;
height:12px;
border-radius:50%;
background:#ddd;
}

.mockup-card{
background:#f8f5ef;
padding:20px;
border-radius:18px;
margin-bottom:16px;
border:1px solid #ece3d7;
}

.mockup-label{
font-size:12px;
font-weight:700;
color:#666;
margin-bottom:8px;
text-transform:uppercase;
}

.mockup-value{
font-size:34px;
font-weight:800;
letter-spacing:-2px;
color:#2a1a10;
}

.problem{
background:white;
}

.section-title{
font-size:52px;
line-height:1.1;
letter-spacing:-2px;
margin-bottom:20px;
}

.section-sub{
font-size:18px;
color:#666;
max-width:720px;
line-height:1.7;
margin-bottom:50px;
}

.cards{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:20px;
}

.card{
background:#faf7f2;
padding:32px;
border-radius:22px;
border:1px solid #eadfce;
transition:.2s;
}

.card:hover{
transform:translateY(-4px);
}

.card h3{
font-size:20px;
margin-bottom:14px;
}

.card p{
color:#666;
line-height:1.7;
font-size:15px;
}

.demo{
background:#2a1a10;
color:white;
}

.demo .section-title{
color:white;
}

.demo .section-sub{
color:#d5cdc2;
}

.demo-box{
background:white;
padding:30px;
border-radius:28px;
max-width:850px;
margin:auto;
color:#111;
}

.grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:18px;
}

.input-group{
margin-bottom:18px;
}

.input-group label{
display:block;
font-size:13px;
font-weight:700;
margin-bottom:8px;
color:#444;
}

.input-group input{
width:100%;
padding:16px;
border-radius:14px;
border:1px solid #ddd;
font-size:15px;
font-family:'DM Sans',sans-serif;
outline:none;
}

.input-group input:focus{
border-color:#6d4c32;
}

.result{
margin-top:30px;
background:#f7f4ef;
padding:34px;
border-radius:24px;
text-align:center;
}

.result small{
display:block;
font-size:13px;
font-weight:700;
color:#666;
margin-bottom:10px;
}

.result h2{
font-size:58px;
letter-spacing:-3px;
color:#2a1a10;
margin-bottom:12px;
}

.result p{
color:#666;
font-size:15px;
}

.pricing{
background:#f5f0e7;
}

.price-box{
max-width:560px;
margin:auto;
background:white;
padding:50px;
border-radius:28px;
text-align:center;
border:1px solid #e7dccb;
box-shadow:0 20px 50px rgba(0,0,0,.05);
}

.old{
text-decoration:line-through;
color:#888;
font-size:20px;
margin-bottom:10px;
}

.price{
font-size:78px;
font-weight:800;
letter-spacing:-5px;
color:#2a1a10;
margin-bottom:20px;
}

.features{
text-align:left;
margin:30px 0;
}

.features li{
list-style:none;
margin-bottom:16px;
font-size:16px;
color:#555;
}

footer{
padding:40px 0;
text-align:center;
font-size:14px;
color:#777;
background:white;
}

.logo{
font-size:24px;
font-weight:800;
letter-spacing:-1px;
margin-bottom:20px;
}

.logo span{
color:#6d4c32;
}

@media(max-width:980px){

.hero-grid,
.cards,
.grid{
grid-template-columns:1fr;
}

.hero{
padding-top:100px;
}

.hero h1{
font-size:52px;
}

.section-title{
font-size:38px;
}

.cards{
gap:16px;
}

.price{
font-size:58px;
}

}

</style>
</head>

<body>

<section class="hero">

<div class="container">

<div class="hero-grid">

<div>

<div class="logo">
Precifica<span>+</span>
</div>

<div class="badge">
SISTEMA DE PRECIFICAÇÃO
</div>

<h1>
Pare de cobrar <span>no escuro.</span>
</h1>

<p>
O Precifica+ mostra quanto você deveria cobrar pelos seus serviços sem trabalhar no prejuízo.
</p>

<div class="buttons">

<a href="#demo" class="btn btn-primary">
Testar agora
</a>

<a href="#preco" class="btn btn-secondary">
Quero acessar
</a>

</div>

</div>

<div>

<div class="mockup">

<div class="mockup-top">
<div class="dot"></div>
<div class="dot"></div>
<div class="dot"></div>
</div>

<div class="mockup-card">

<div class="mockup-label">
Hora recomendada
</div>

<div class="mockup-value">
R$ 87/h
</div>

</div>

<div class="mockup-card">

<div class="mockup-label">
Projeto calculado
</div>

<div class="mockup-value">
R$ 2.610
</div>

</div>

<div class="mockup-card">

<div class="mockup-label">
Situação
</div>

<div class="mockup-value">
Lucro saudável
</div>

</div>

</div>

</div>

</div>

</div>

</section>

<section class="problem">

<div class="container">

<h2 class="section-title">
Você não precisa cobrar mais barato.
Precisa cobrar certo.
</h2>

<p class="section-sub">
A maioria dos profissionais trabalha demais porque nunca aprendeu a transformar seu tempo em preço.
</p>

<div class="cards">

<div class="card">
<h3>Trabalha muito</h3>
<p>
Entrega mais do que deveria e no fim do mês sobra pouco.
</p>
</div>

<div class="card">
<h3>Cobra no feeling</h3>
<p>
Escolhe um valor baseado no medo do cliente achar caro.
</p>
</div>

<div class="card">
<h3>Não sabe sua hora</h3>
<p>
Mistura lucro, custo de vida e preço sem estratégia.
</p>
</div>

<div class="card">
<h3>Vive inseguro</h3>
<p>
Toda proposta parece um chute.
</p>
</div>

</div>

</div>

</section>

<section class="demo" id="demo">

<div class="container">

<h2 class="section-title">
Teste o Precifica+ agora
</h2>

<p class="section-sub">
Veja em segundos quanto você deveria cobrar.
</p>

<div class="demo-box">

<div class="grid">

<div class="input-group">
<label>Custo de vida mensal</label>
<input type="number" id="vida" value="2500">
</div>

<div class="input-group">
<label>Lucro desejado</label>
<input type="number" id="lucro" value="2000">
</div>

<div class="input-group">
<label>Custos fixos</label>
<input type="number" id="custos" value="600">
</div>

<div class="input-group">
<label>Horas disponíveis no mês</label>
<input type="number" id="horas" value="120">
</div>

</div>

<div class="result">

<small>VOCÊ DEVERIA COBRAR</small>

<h2 id="resultado">
R$ 0
</h2>

<p>
Valor calculado com base nos seus custos e disponibilidade.
</p>

</div>

</div>

</div>

</section>

<section class="pricing" id="preco">

<div class="container">

<div class="price-box">

<div class="logo" style="margin-bottom:10px;">
Precifica<span>+</span>
</div>

<h2 class="section-title">
Acesse agora
</h2>

<div class="old">
de R$97
</div>

<div class="price">
R$29
</div>

<p style="color:#666;font-size:16px;">
Pagamento único • acesso imediato
</p>

<ul class="features">

<li>✔ Sistema de precificação</li>
<li>✔ Cálculo automático da hora</li>
<li>✔ Montagem de escopo</li>
<li>✔ Simulação estratégica</li>
<li>✔ Evita prejuízo</li>
<li>✔ Clareza para enviar propostas</li>

</ul>

<a href="#" class="btn btn-primary" style="width:100%;">
Quero acessar o Precifica+
</a>

</div>

</div>

</section>

<footer>
Precifica+ © 2026
</footer>

<script>

function calcular(){

const vida =
Number(document.getElementById('vida').value);

const lucro =
Number(document.getElementById('lucro').value);

const custos =
Number(document.getElementById('custos').value);

const horas =
Number(document.getElementById('horas').value);

const total =
vida + lucro + custos;

const hora =
total / horas;

const projeto =
hora * 30;

document.getElementById('resultado')
.innerText =
projeto.toLocaleString('pt-BR',{
style:'currency',
currency:'BRL'
});

}

document.querySelectorAll('input')
.forEach(input=>{
input.addEventListener('input',calcular);
});

calcular();

</script>

</body>
</html>
